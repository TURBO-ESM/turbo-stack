module test_min_across_pes_real64_1d
  use pfunit
  use MOM_coms_infra, only : min_across_PEs
  use MOM_test_case
  use iso_fortran_env, only : int32, real64
  implicit none

  @testCase()
  type, extends(MOM_MPI_test_case) :: test_case_min_across_pes
  end type test_case_min_across_pes

contains

  @test(npes=[4])
  subroutine test_MinAcrossPEs(this)
    class (test_case_min_across_pes), intent(inout) :: this
    integer(kind=int32) :: comm_size, comm_rank
    real(kind=real64), dimension(:), allocatable :: expected_global_min
    real(kind=real64), dimension(:), allocatable :: actual_global_min
    real(kind=real64), parameter :: tolerance = 1.0e-12_real64

    comm_size = this%getNumProcesses()
    comm_rank = this%getProcessRank()

    allocate(expected_global_min(comm_size))
    expected_global_min = -1.5_real64
    expected_global_min(1) = -0.75_real64

    allocate(actual_global_min(comm_size))
    actual_global_min = 0.5_real64*real(comm_rank-3, kind=real64)
    actual_global_min(1) = 0.5_real64*actual_global_min(1)
    call min_across_PEs(actual_global_min, size(actual_global_min))

    @assertEqual(expected_global_min, actual_global_min, tolerance=tolerance)

    deallocate(expected_global_min)
    deallocate(actual_global_min)

  end subroutine test_MinAcrossPEs
   
end module test_min_across_pes_real64_1d
