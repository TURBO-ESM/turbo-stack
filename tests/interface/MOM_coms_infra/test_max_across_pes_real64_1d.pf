module test_max_across_pes_real64_1d
  use pfunit
  use MOM_coms_infra, only : max_across_PEs
  use MOM_test_case
  use iso_fortran_env, only : int32, real64
  implicit none

  @testCase()
  type, extends(MOM_MPI_test_case) :: test_case_max_across_pes
  end type test_case_max_across_pes

contains

  @test(npes=[4])
  subroutine test_MaxAcrossPEs(this)
    class (test_case_max_across_pes), intent(inout) :: this
    integer(kind=int32) :: comm_size, comm_rank
    real(kind=real64), dimension(:), allocatable :: expected_global_max
    real(kind=real64), dimension(:), allocatable :: actual_global_max

    comm_size = this%getNumProcesses()
    comm_rank = this%getProcessRank()

    allocate(expected_global_max(comm_size))
    expected_global_max = 1.5_real64
    expected_global_max(1) = 0.75_real64

    allocate(actual_global_max(comm_size))
    actual_global_max = -0.5_real64*real(comm_rank-3, kind=real64)
    actual_global_max(1) = 0.5_real64*actual_global_max(1)
    call max_across_PEs(actual_global_max, size(actual_global_max))

    @assertEqual(expected_global_max, actual_global_max)

    deallocate(expected_global_max)
    deallocate(actual_global_max)

  end subroutine test_MaxAcrossPEs

end module test_max_across_pes_real64_1d
