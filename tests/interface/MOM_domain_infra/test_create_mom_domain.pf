module test_create_mom_domain
  use pfunit
  use MOM_test_case
  use MOM_domains, only : MOM_domain_type, create_MOM_domain
  use iso_fortran_env, only : int32
  implicit none

  type :: create_mom_domain_args_type
    integer(kind=int32) :: n_global(2)  = (/4, 8/)
    integer(kind=int32) :: n_halo(2)    = (/1, 1/)
    logical :: reentrant(2) = (/ .false., .false. /)
    logical :: tripolar_N   = .false.
    integer(kind=int32) :: layout(2)    = (/2, 2/)
    logical :: thin_halos   = .true.
    logical :: nonblocking  = .false.
    logical :: symmetric    = .false.
    character(len=20) :: name = "MOM"
    integer(kind=int32) :: io_layout(2) = (/1, 1/)
  end type create_mom_domain_args_type

  @testCase()
  type, extends(MOM_MPI_test_case) :: testcase_domain
  end type testcase_domain

contains

  @test(npes=[4])
  subroutine create_mom_domain_test(this)
    class (testcase_domain), intent(inout) :: this

    ! Using blocks to test multiple cases of domain creation with different arguments.
    ! Each block has its own scope so we can reuse variable names and ensure proper deallocation of the domain after each test case

    ! Default case with default arguments
    block
      type(MOM_domain_type), pointer :: dom => null()
      type(create_mom_domain_args_type) :: args
      call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
        symmetric=args%symmetric, thin_halos=args%thin_halos, nonblocking=args%nonblocking)
      call check_domain(dom, args)
      if (associated(dom)) deallocate(dom)
    end block

    ! Change reentrant flag
    block
      integer :: i, j
      logical :: reentrant_x, reentrant_y
      
      do i = 0, 1
        do j = 0, 1
          reentrant_x = (i == 1)
          reentrant_y = (j == 1)
          block
            type(MOM_domain_type), pointer :: dom => null()
            type(create_mom_domain_args_type) :: args

            args%reentrant = (/ reentrant_x, reentrant_y /)
            if (reentrant_y .and. args%tripolar_N) then
              cycle ! skip the invalid case of tripolar_N true with reentrant_y true since this is not currently supported in create_MOM_domain
            end if

            call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
              symmetric=args%symmetric, thin_halos=args%thin_halos, nonblocking=args%nonblocking)
            call check_domain(dom, args)

            if (associated(dom)) deallocate(dom)
          end block
        end do
      end do
    end block

  end subroutine create_mom_domain_test

  subroutine check_domain(dom, create_mom_domain_args)
    type(MOM_domain_type), pointer, intent(in) :: dom
    type(create_mom_domain_args_type), intent(in) :: create_mom_domain_args
    ! These values are pulled in from mpp?
    integer(kind=int32), parameter :: CYCLIC_GLOBAL_DOMAIN = 2

    !call assertAssociated(dom)
    call assertTrue(associated(dom))

    call assertEqual(dom%name, create_mom_domain_args%name)

    call assertEqual(dom%nonblocking_updates, create_mom_domain_args%nonblocking)
    call assertEqual(dom%thin_halo_updates, create_mom_domain_args%thin_halos)
    call assertEqual(dom%symmetric, create_mom_domain_args%symmetric)

    call assertEqual(dom%niglobal, create_mom_domain_args%n_global(1))
    call assertEqual(dom%njglobal, create_mom_domain_args%n_global(2))

    call assertEqual(dom%nihalo, create_mom_domain_args%n_halo(1))
    call assertEqual(dom%njhalo, create_mom_domain_args%n_halo(2))

    ! XFLAGS and YFLAGS are set to be special values from mpp_domain?... for now just hardcoding the expected values based on the reentrant input
    if (create_mom_domain_args%reentrant(1)) then
      call assertEqual(dom%X_FLAGS, CYCLIC_GLOBAL_DOMAIN)
    else
      call assertEqual(dom%X_FLAGS, 0)
    end if

    if (create_mom_domain_args%reentrant(2)) then
      call assertEqual(dom%Y_FLAGS, CYCLIC_GLOBAL_DOMAIN)
    else if (create_mom_domain_args%tripolar_N) then
      call assertEqual(dom%Y_FLAGS, 2**5)
    else
      call assertEqual(dom%Y_FLAGS, 0)
    end if

    call assertEqual(dom%layout, create_mom_domain_args%layout)

    ! More logic about how to set io_layout based on the input arguments in create_MOM_domain, but for now just checking it matches the input value
    call assertEqual(dom%io_layout, create_mom_domain_args%io_layout)

    ! TODO:Logic about how to set MOM_dom%maskmap based on the input arguments in create_MOM_domain, but for now just checking it is set to the expected value of 0
    ! check that this is a null pointer.
    call assertFalse(associated(dom%maskmap))

    call assertEqual(dom%turns, 0)

    ! TODO: Not checking mpp_domain and mpp_domain2 pointers at the moment
    ! Check that these are not null pointers, but not checking the actual contents of the domains at this time
    call assertTrue(associated(dom%mpp_domain))
    call assertTrue(associated(dom%mpp_domain_d2))

  end subroutine check_domain


end module test_create_mom_domain
