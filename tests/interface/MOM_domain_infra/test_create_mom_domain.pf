module test_create_mom_domain
  use pfunit
  use MOM_test_case
  use MOM_domains, only : MOM_domain_type, create_MOM_domain
  use iso_fortran_env, only : int32
  implicit none

  type :: create_mom_domain_args_type
    integer(kind=int32) :: n_global(2)  = (/4, 8/)
    integer(kind=int32) :: n_halo(2)    = (/1, 1/)
    logical :: reentrant(2) = (/ .false., .false. /)
    logical :: tripolar_N   = .false.
    integer(kind=int32) :: layout(2)    = (/2, 2/)
    logical :: thin_halos   = .true.  ! Marked as optional but will segfault if not given as an argument to create_MOM_domain
    logical :: nonblocking  = .false. ! Marked as optional but will segfault if not given as an argument to create_MOM_domain
    logical :: symmetric    = .true.
    character(len=20) :: name = "MOM"
    integer(kind=int32) :: io_layout(2) = (/1, 1/)
    ! Not covering mask table for now. It's a file?
  end type create_mom_domain_args_type

  @testCase()
  type, extends(MOM_MPI_test_case) :: testcase_domain
  end type testcase_domain

contains

  @test(npes=[4])
  subroutine create_mom_domain_test(this)
    class (testcase_domain), intent(inout) :: this

    ! Using blocks to test multiple cases of domain creation with different arguments.
    ! Each block has its own scope so we can reuse variable names and ensure proper deallocation of the domain after each test case

    !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    ! Default case with default arguments
    !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    block
      type(MOM_domain_type), pointer :: dom => null()
      type(create_mom_domain_args_type) :: args
      call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
        thin_halos=args%thin_halos, nonblocking=args%nonblocking)
      call check_domain(dom, args)
      if (associated(dom)) deallocate(dom)
    end block

    !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    ! Required arguments with non default values
    !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

    ! Change n_global
    block
      integer(kind=int32) :: n_global_x, n_global_y
      ! TODO: These fail for values of 1, 2, and 3. Is that expected given the other arguments are left at their default values? 
      do n_global_x = 4, 8
        do n_global_y = 4, 8
          block
            type(MOM_domain_type), pointer :: dom => null()
            type(create_mom_domain_args_type) :: args

            args%n_global = (/ n_global_x, n_global_y /)

            call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
              thin_halos=args%thin_halos, nonblocking=args%nonblocking)
            call check_domain(dom, args)

            if (associated(dom)) deallocate(dom)
          end block
        end do
      end do
    end block

    ! Change n_halo
    block
      integer(kind=int32) :: n_halo_x, n_halo_y
      do n_halo_x = 1, 2
        do n_halo_y = 1, 2
          block
            type(MOM_domain_type), pointer :: dom => null()
            type(create_mom_domain_args_type) :: args

            args%n_halo = (/ n_halo_x, n_halo_y /)

            call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
              thin_halos=args%thin_halos, nonblocking=args%nonblocking)
            call check_domain(dom, args)

            if (associated(dom)) deallocate(dom)
          end block
        end do
      end do
    end block

    ! Change reentrant flag
    block
      integer :: is_reentrant_x, is_reentrant_y
      do is_reentrant_x = 0, 1
        do is_reentrant_y = 0, 1
          block
            type(MOM_domain_type), pointer :: dom => null()
            type(create_mom_domain_args_type) :: args

            args%reentrant = (/ (is_reentrant_x == 1), (is_reentrant_y == 1) /)

            call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
              thin_halos=args%thin_halos, nonblocking=args%nonblocking)
            call check_domain(dom, args)

            if (associated(dom)) deallocate(dom)
          end block
        end do
      end do
    end block

    ! Change tripolar_N flag
    block
      integer :: is_tripolar_N
      do is_tripolar_N = 0, 1
        block
          type(MOM_domain_type), pointer :: dom => null()
          type(create_mom_domain_args_type) :: args

          args%tripolar_N = (is_tripolar_N == 1)

          call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
            thin_halos=args%thin_halos, nonblocking=args%nonblocking)
          call check_domain(dom, args)

          if (associated(dom)) deallocate(dom)
        end block
      end do
    end block

    ! Change layout
    block


      ! TODO: This Fails
      ! integer(kind=int32), parameter :: layout_x_values(3) = (/4, 2, 1/)
      ! integer(kind=int32), parameter :: layout_y_values(3) = (/1, 2, 4/)
      ! Fall back to this default value to get it to pass for now. Come back and see how layout is used in create_MOM_domain and what reasonable values for these arguments should be.
      integer(kind=int32), parameter :: layout_x_values(1) = (/2/)
      integer(kind=int32), parameter :: layout_y_values(1) = (/2/)

      integer(kind=int32) :: i, j
      do i = 1, size(layout_x_values)
        do j = 1, size(layout_y_values)
          block
            type(MOM_domain_type), pointer :: dom => null()
            type(create_mom_domain_args_type) :: args

            args%layout = (/ layout_x_values(i), layout_y_values(j) /)

            call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
              thin_halos=args%thin_halos, nonblocking=args%nonblocking)
            call check_domain(dom, args)

            if (associated(dom)) deallocate(dom)
          end block
        end do
      end do

    end block

    ! TODO: thin_halos and nonblocking are optional arguments in create_MOM_domain but create_MOM_domain will segfault if not given,
    !       Not testing them here in the required arguments section but maybe we should?

    !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    ! Optional arguments with non default values
    !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

    ! Change name
    block
      type(MOM_domain_type), pointer :: dom => null()
      type(create_mom_domain_args_type) :: args

      args%name = "some_domain_name"

      call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
        thin_halos=args%thin_halos, nonblocking=args%nonblocking, domain_name=args%name)
      call check_domain(dom, args)

      if (associated(dom)) deallocate(dom)
    end block

    ! Change all arguments, a bunch of nested loops to test multiple combinations of arguments for create_MOM_domain.
    block
      ! User input here: For setting loop bounds for non bool arguments to create_MOM_domain
      integer(kind=int32), parameter :: n_global_x_min = 4, n_global_x_max = 8  ! TODO: These fail for values of 1, 2, and 3. Is that expected given the other arguments are left at their default values? 
      integer(kind=int32), parameter :: n_global_y_min = 4, n_global_y_max = 8  ! TODO: These fail for values of 1, 2, and 3. Is that expected given the other arguments are left at their default values? 
      integer(kind=int32), parameter :: n_halo_x_min = 0, n_halo_x_max = 2
      integer(kind=int32), parameter :: n_halo_y_min = 0, n_halo_y_max = 2
      integer(kind=int32), parameter :: layout_x_min = 2, layout_x_max = 2      ! TODO: This Fails for values other than min=max=2. Come back and see how layout is used in create_MOM_domain and what reasonable values for these arguments should be.
      integer(kind=int32), parameter :: layout_y_min = 2, layout_y_max = 2      ! TODO: This Fails for values other than min=max=2. Come back and see how layout is used in create_MOM_domain and what reasonable values for these arguments should be.
      integer(kind=int32), parameter :: name_idx_min = 1, name_idx_max = 2
      integer(kind=int32), parameter :: io_layout_x_min = 1, io_layout_x_max = 2 ! TODO: Pick reasonable values to loop over for this arguments
      integer(kind=int32), parameter :: io_layout_y_min = 1, io_layout_y_max = 2 ! TODO: Pick reasonable values to loop over for this arguments
      ! Variables used to set arguments to create_MOM_domain inside of the following loops
      integer(kind=int32) :: n_global_x, n_global_y
      integer(kind=int32) :: n_halo_x, n_halo_y
      integer(kind=int32) :: is_reentrant_x, is_reentrant_y
      integer(kind=int32) :: is_tripolar_N
      integer(kind=int32) :: layout_x, layout_y
      integer(kind=int32) :: is_thin_halos
      integer(kind=int32) :: is_nonblocking
      integer(kind=int32) :: is_symmetric
      integer(kind=int32) :: name_idx
      integer(kind=int32) :: io_layout_x, io_layout_y
     
      n_global_x_loop : do n_global_x = n_global_x_min, n_global_x_max
      n_global_y_loop : do n_global_y = n_global_y_min, n_global_y_max
      n_halo_x_loop : do n_halo_x = n_halo_x_min, n_halo_x_max
      n_halo_y_loop : do n_halo_y = n_halo_y_min, n_halo_y_max
      is_reentrant_x_loop : do is_reentrant_x = 0, 1
      is_reentrant_y_loop : do is_reentrant_y = 0, 1
      is_tripolar_N_loop : do is_tripolar_N = 0, 1
      layout_x_loop : do layout_x = layout_x_min, layout_x_max
      layout_y_loop : do layout_y = layout_y_min, layout_y_max
      thin_halos_loop : do is_thin_halos = 0, 1
      nonblocking_loop : do is_nonblocking = 0, 1
      symmetric_loop : do is_symmetric = 0, 1
      name_loop : do name_idx = name_idx_min, name_idx_max
      io_layout_x_loop : do io_layout_x = io_layout_x_min, io_layout_x_max
      io_layout_y_loop : do io_layout_y = io_layout_y_min, io_layout_y_max
        block
          type(MOM_domain_type), pointer :: dom => null()
          type(create_mom_domain_args_type) :: args

          args%n_global = (/ n_global_x, n_global_y /)
          args%n_halo = (/ n_halo_x, n_halo_y /)
          args%reentrant = (/ (is_reentrant_x == 1), (is_reentrant_y == 1) /)
          args%tripolar_N = (is_tripolar_N == 1)
          args%layout = (/ layout_x, layout_y /)
          args%thin_halos = (is_thin_halos == 1)
          args%nonblocking = (is_nonblocking == 1)
          args%symmetric = (is_symmetric == 1)
          if (name_idx == 1) then
            args%name = "MOM_domain_name"
          else if (name_idx == 2) then
            args%name = "MOM_domain_name2"
          end if
          args%io_layout = (/ io_layout_x, io_layout_y /)

          ! Can't have reentrant_y true with tripolar_N true
          if (args%reentrant(2) .and. args%tripolar_N) then
            cycle ! skip the invalid case of tripolar_N true with reentrant_y true since this is not currently supported in create_MOM_domain
          end if

          ! TODO: Skip tripolar cases for now because it segfaults for some cases. Not sure what combination of other arguments lead to this. Determine which combinations of arguments are valid for create_MOM_domain with tripolar_N later.
          if (args%tripolar_N ) then
            cycle 
          end if

          call create_MOM_domain(dom, args%n_global, args%n_halo, args%reentrant, args%tripolar_N, args%layout, &
            symmetric=args%symmetric, thin_halos=args%thin_halos, nonblocking=args%nonblocking, io_layout=args%io_layout, &
            domain_name=args%name)
          call check_domain(dom, args)

          if (associated(dom)) deallocate(dom)
        end block
      end do io_layout_y_loop
      end do io_layout_x_loop
      end do name_loop
      end do symmetric_loop
      end do nonblocking_loop
      end do thin_halos_loop
      end do layout_y_loop
      end do layout_x_loop
      end do is_tripolar_N_loop
      end do is_reentrant_y_loop
      end do is_reentrant_x_loop
      end do n_halo_y_loop
      end do n_halo_x_loop
      end do n_global_y_loop
      end do n_global_x_loop
    end block

  end subroutine create_mom_domain_test

  subroutine check_domain(dom, create_mom_domain_args)
    type(MOM_domain_type), pointer, intent(in) :: dom
    type(create_mom_domain_args_type), intent(in) :: create_mom_domain_args
    ! These values are pulled in from mpp?
    integer(kind=int32), parameter :: CYCLIC_GLOBAL_DOMAIN = 2

    !call assertAssociated(dom)
    @assertTrue(associated(dom))

    @assertEqual(dom%name, create_mom_domain_args%name)

    @assertEqual(dom%nonblocking_updates, create_mom_domain_args%nonblocking)
    @assertEqual(dom%thin_halo_updates, create_mom_domain_args%thin_halos)
    @assertEqual(dom%symmetric, create_mom_domain_args%symmetric)

    @assertEqual(dom%niglobal, create_mom_domain_args%n_global(1))
    @assertEqual(dom%njglobal, create_mom_domain_args%n_global(2))

    @assertEqual(dom%nihalo, create_mom_domain_args%n_halo(1))
    @assertEqual(dom%njhalo, create_mom_domain_args%n_halo(2))

    ! XFLAGS and YFLAGS are set to be special values from mpp_domain?... for now just hardcoding the expected values based on the reentrant input
    if (create_mom_domain_args%reentrant(1)) then
      @assertEqual(dom%X_FLAGS, CYCLIC_GLOBAL_DOMAIN)
    else
      @assertEqual(dom%X_FLAGS, 0)
    end if

    if (create_mom_domain_args%reentrant(2)) then
      @assertEqual(dom%Y_FLAGS, CYCLIC_GLOBAL_DOMAIN)
    else if (create_mom_domain_args%tripolar_N) then
      @assertEqual(dom%Y_FLAGS, 2**5)
    else
      @assertEqual(dom%Y_FLAGS, 0)
    end if

    @assertEqual(dom%layout, create_mom_domain_args%layout)

    ! More logic about how to set io_layout based on the input arguments in create_MOM_domain, but for now just checking it matches the input value
    @assertEqual(dom%io_layout, create_mom_domain_args%io_layout)

    ! TODO:Logic about how to set MOM_dom%maskmap based on the input arguments in create_MOM_domain, but for now just checking it is set to the expected value of 0
    ! check that this is a null pointer.
    @assertFalse(associated(dom%maskmap))

    @assertEqual(dom%turns, 0)

    ! TODO: Not checking mpp_domain and mpp_domain2 pointers at the moment
    ! Check that these are not null pointers, but not checking the actual contents of the domains at this time
    @assertTrue(associated(dom%mpp_domain))
    @assertTrue(associated(dom%mpp_domain_d2))

  end subroutine check_domain


end module test_create_mom_domain
