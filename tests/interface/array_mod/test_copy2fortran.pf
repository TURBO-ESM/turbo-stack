module test_copy2fortran
  use pfunit
  use array_mod
  use MOM_test_case
  implicit none

  @testCase()
  type, extends(MOM_MPI_test_case) :: testcase_duplicate
  end type testcase_duplicate

contains

  @test(npes=[4])
  subroutine test_array_copy2F(this)
    class (testcase_duplicate), intent(inout) :: this
    integer, parameter :: n1 = 45, n2 = 12
    real, dimension(:,:),pointer :: array_expected
    type(RealArray_t) :: array_A
    real, dimension(n1,n2) :: array_actual
    integer :: i,j

    ! Duplicate the size of a Fortran array
    call array_A%dup(array_actual)

    ! Get a view of the ArrayReal_t
    call array_A%view(array_expected)
   
    do j=1,n2
      do i=1,n1
        array_expected(i,j) = real(i) + 2.3*real(j)
      enddo
    enddo

    ! Copy the values into the Array container 
    call array_A%copy2F(array_actual)

    @assertEqual(array_expected, array_actual)

  end subroutine test_array_copy2f

end module test_copy2fortran
