module test_duplicate_full
  use pfunit
  use array_mod
  use MOM_test_case
  implicit none

  @testCase()
  type, extends(MOM_MPI_test_case) :: testcase_duplicate
  end type testcase_duplicate

contains

  @test(npes=[4])
  subroutine test_array_duplicate(this)
    class (testcase_duplicate), intent(inout) :: this
    integer, parameter :: n1 = 45, n2 = 12
    real, dimension(n1,n2) :: array_F  
    type(RealArray_t) :: array_A
    integer, dimension(2) :: lb_actual, ub_actual
    integer, dimension(2) :: lb_expected, ub_expected

    
    lb_expected = [1, 1]
    ub_expected = [n1, n2]

    ! Duplicate the size of a Fortran array
    call array_A%dup(array_F)
    lb_actual = array_A%lb
    ub_actual = array_A%ub

    @assertEqual(lb_expected, lb_actual)
    @assertEqual(ub_expected, ub_actual)

  end subroutine test_array_duplicate

end module test_duplicate_full
